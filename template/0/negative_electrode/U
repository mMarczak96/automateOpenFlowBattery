FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0/negative_electrode";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform {{ internalField }};

boundaryField
{
    #include "$FOAM_CASE/include/setConstraintTypes"

    inlet_negative_electrode
    {
        type            fixedValue;
        value           $internalField;
    }
    outlet_negative_electrode
    {
        type            pressureInletOutletVelocity;
        value           $internalField;
    }
    negative_electrode_to_cc
    {
        type            {{ wallBCtype }};
    }
    negative_electrode_to_separator
    {
        type            {{ wallBCtype }};
    }
    frontAndBack
    {
        type            empty;
    }
}


