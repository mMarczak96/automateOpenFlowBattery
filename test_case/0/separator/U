FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0/separator";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    #include "$FOAM_CASE/include/setConstraintTypes"
    walls_separator
    {
        type            zeroGradient;
    }
    separator_to_negative_electrode
    {
        type            zeroGradient;
    }
    separator_to_positive_electrode
    {
        type            zeroGradient;
    }
    frontAndBack
    {
        type            empty;
    }
}


