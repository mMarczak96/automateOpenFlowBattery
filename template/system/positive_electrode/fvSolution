FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system/negative_electrode";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "p.*"
    {
        solver           GAMG;
        smoother         symGaussSeidel;
        tolerance        1e-7;
        relTol           0.01;
    }

    "(U|h).*"
    {
        solver           PBiCGStab;
        preconditioner   DILU;
        tolerance        1e-7;
        relTol           0.1;
    }

    "(V|SO4|HSO4).*"
    {
        solver           PBiCGStab;
        preconditioner   DILU;
        tolerance        1e-7;
        relTol           1e-3;
        minIter          1;
    }

    "electrode_potential"
    {
        solver           GAMG;
        smoother         symGaussSeidel;
        tolerance        1e-7;
        relTol           1e-3;
        minIter          1;
    }
}

PIMPLE
{
    momentumPredictor   yes;
    thermophysics       yes;
}

relaxationFactors
{
    fields
    {
        p               	{{ p_alphaRelax }};
    }
    equations
    {
        U               	{{ U_alphaRelax }};
        electrode_potential     {{ electrode_potential_alphaRelax }};
        VO			{{ specie_alphaRelax }};
        VO2			{{ specie_alphaRelax }};
        HSO4		 	{{ specie_alphaRelax }};
        SO4		 	{{ specie_alphaRelax }};
    }
}

