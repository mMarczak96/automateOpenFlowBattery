FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/positive_electrode";
    object      electrolyte_potential;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 2 -3 0 0 -1 0];

internalField   uniform 0;

boundaryField
{
    frontAndBack
    {
        type            empty;
    }
    inlet_positive_electrode
    {
        type            zeroGradient;
    }
    outlet_positive_electrode
    {
        type            zeroGradient;
    }
    positive_electrode_to_cc
    {
        type            potentialZeroCurrentMixed;
        region          positive_electrode;
        value           uniform 0;
    }
    positive_electrode_to_separator
    {
        type             donnanPotentialBaffleMixed;
        potentialNbr     electrolyte_potential;
        ionicSpeciesName H;
        mode             ;
        value            uniform 0;
    }
}


