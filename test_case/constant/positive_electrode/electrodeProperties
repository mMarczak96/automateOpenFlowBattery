FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/positive_electrode";
    object      electrodeProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type            singlePhasePorousElectrode;
specificArea    30000;
conductivity    500;
initField       0;

kinetics
{
    type                butlerVolmer;
    linearizeCurrent    true;
    alpha               0.5;
    nElectrons          1;
    K0                  2.5e-08;
    initField           0;
    iLim                100;
}


