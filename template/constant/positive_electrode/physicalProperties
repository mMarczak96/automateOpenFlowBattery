FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/positive_electrode";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       {{ molWeight }};
    }
    equationOfState
    {
        rho             {{ rho }};
    }
    thermodynamics
    {
        Cp              {{ Cp }};
        Hf              {{ Hf }};
    }
    transport
    {
        mu              {{ mu }};
        Pr              {{ Pr }};
    }
}

