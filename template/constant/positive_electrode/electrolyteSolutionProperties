FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/positive_electrode";
    object      solutionProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type                {{ type }};
speciesNumber       {{ speciesNumber }};

vanadiumComponents       {{ vanadiumComponents }};
vanadiumCompCharges      {{ vanadiumCompCharges }};
vanadiumOxidationStates  {{ vanadiumOxidationStates }};

molecularDiffusivity     {{ molDiff }};

smallConc           {{ smallConc }};
minActiveConc       {{ minActiveConc }};

nernstEquation
{
    E0                      {{ E0_nernst }};
    nElectrons              {{ nElectrons }};
    
    numeratorCompNames      {{ numNames }};
    numeratorCompExponents  {{ numExp }};
    denominatorCompNames    {{ denNames }};
    denominatorCompExponents {{ denExp }};
}

