FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/positive_electrode";
    object      electrodeProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type            {{ type }};
specificArea    {{ specificArea }};
conductivity    {{ conductivity }};
initField       {{ initField }};

kinetics
{
    type                {{ kineticsType }};
    linearizeCurrent    {{ linearizeCurrent }};
    alpha               {{ alpha }};
    nElectrons          {{ nElectrons }};
    K0                  {{ K0 }};
    initField           {{ initFieldK }};
    iLim                {{ iLim }};
}


