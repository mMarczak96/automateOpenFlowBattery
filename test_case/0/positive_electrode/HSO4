FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/positive_electrode";
    object      HSO4;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -3 0 0 1 0 0];

internalField   uniform 3000;

initialConcentration 3000;
boundaryField
{
    #include "$FOAM_CASE/include/setConstraintTypes"

    inlet_positive_electrode
    {
        type            fixedValue;
        value           uniform $initialConcentration;
    }
    outlet_positive_electrode
    {
        type            zeroGradient;
    }
    walls_positive_electrode
    {
        type            zeroGradient;
    }
    positive_electrode_to_cc
    {
        type              ionicSpeciesZeroFluxMixed;
        potential         electrolyte_potential;
        initialConc       $initialConcentration;
        mode		  1;
        alpha		  0.1;
        value             uniform $initialConcentration; 
    }
    positive_electrode_to_separator
    {
        type              ionicSpeciesZeroFluxMixed;
        potential         electrolyte_potential;
        initialConc       $initialConcentration;
        mode		  1;
        alpha		  0.1;
        value             uniform $initialConcentration; 
    }
    frontAndBack
    {
        type            empty;
    }
}


