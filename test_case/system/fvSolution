FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "electrolyte_potential"
    {
        solver           GAMG;
        smoother         symGaussSeidel;
        tolerance        1e-8;
        relTol           1e-6;
        minIter          1;
    }
}

PIMPLE
{
    potential                          on;
    nElectrolytePotentialCorrectors    100;
    controlMethod                      galvanostatic;
    fluidFlow       		       false;
    linearizeSourceTerm		       false;
}

relaxationFactors
{
    fields
    {

    }

    equations
    {
        electrolyte_potential 0.6;
    }
}

