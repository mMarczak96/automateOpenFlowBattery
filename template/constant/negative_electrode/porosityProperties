FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/negative_electrode";
    object      porosityProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

porosity1
{
    type            {{ type }};

    cellZone        {{ cellZone }};

    porosity        {{ porosity }};

    alpha {{ alpha }}; // kinematic viscosity divided by permeability

    beta {{ beta }};

    rhoRef {{ rhoRef }};

    coordinateSystem
    {
        type    cartesian;
        origin  (0 0 0);
        coordinateRotation
        {
            type    axesRotation;
            e1      (1 0 0);
            e2      (0 1 0);
        }
    }
}


