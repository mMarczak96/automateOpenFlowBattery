FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/positive_electrode";
    object      porosityProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

porosity1
{
    type            fixedCoeff;

    cellZone        positive_electrode;

    porosity        0.84;

    alpha (1e4 1e4 1e4); // kinematic viscosity divided by permeability

    beta (0 0 0);

    rhoRef 1e3;

    coordinateSystem
    {
        type    cartesian;
        origin  (0 0 0);
        coordinateRotation
        {
            type    axesRotation;
            e1      (1 0 0);
            e2      (0 1 0);
        }
    }
}


