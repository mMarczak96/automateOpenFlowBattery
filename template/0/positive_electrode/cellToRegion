internalField   uniform 3;

boundaryField
{
    frontAndBack
    {
        type            empty;
    }
    inlet_positive_electrode
    {
        type            zeroGradient;
    }
    outlet_positive_electrode
    {
        type            zeroGradient;
    }
    positive_electrode_to_cc
    {
        type            zeroGradient;
    }
    positive_electrode_to_separator
    {
        type            zeroGradient;
    }
}


