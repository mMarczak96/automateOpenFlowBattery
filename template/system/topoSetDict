FoamFile
{
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Enter again values from the blockMeshDict (in mm)
separator_thickness #calc "0.2 * 0.001";
electrode_thickness #calc "4 * 0.001";

negElecEnd #calc "-1 * $electrode_thickness - $separator_thickness / 2";
posElecEnd #calc "$electrode_thickness + $separator_thickness / 2";
negSepEnd  #calc "-1 * $separator_thickness / 2";
posSepEnd  #calc "$separator_thickness / 2";

actions
(
    {
        action  new;
        type    faceSet;
        name    f_walls_cc_n;
        source patchToFace;
        patch  "walls";
    }

    {
        action  delete;
        type    faceSet;
        name    f_walls_cc_n;
        source boxToFace;
        box   (-1 -1 $negElecEnd) (1 1 1);
    }

    {
        action  new;
        type    faceSet;
        name    f_walls_cc_p;
        source patchToFace;
        patch  "walls";
    }

    {
        action  delete;
        type    faceSet;
        name    f_walls_cc_p;
        source boxToFace;
        box   (-1 -1 -1) (1 1 $posElecEnd);
    }

    {
        action  new;
        type    faceSet;
        name    f_walls_electrode_n;
        source patchToFace;
        patch  "walls";
    }

    {
        action  delete;
        type    faceSet;
        name    f_walls_electrode_n;
        source boxToFace;
        boxes   ((-1 -1 -1) (1 1 $negElecEnd)   (-1 -1 $negSepEnd) (1 1 1));
    }

    {
        action  new;
        type    faceSet;
        name    f_walls_electrode_p;
        source patchToFace;
        patch  "walls";
    }

    {
        action  delete;
        type    faceSet;
        name    f_walls_electrode_p;
        source boxToFace;
        boxes   ((-1 -1 -1) (1 1 $posSepEnd)   (-1 -1 $posElecEnd) (1 1 1));
    }

    {
        action  new;
        type    faceZoneSet;
        name    electrode_cc_n;
        source planeToFaceZone;
        point   (0 0 $negElecEnd);
        normal  (0 0 -1);  // orientation is important for separating regions
        include all;          // Take all faces (default)
        // include closest;   // Take the closest contiguous region of
                      // faces to the plane point
    }

    {
        action  new;
        type    faceZoneSet;
        name    electrode_cc_p;
        source planeToFaceZone;
        point   (0 0 $posElecEnd);
        normal  (0 0 1);  // orientation is important for separating regions
        include all;          // Take all faces (default)
        // include closest;   // Take the closest contiguous region of
                      // faces to the plane point
    }

    {
        action  new;
        type    faceZoneSet;
        name    electrode_s_n;
        source planeToFaceZone;
        point   (0 0 $negSepEnd);
        normal  (0 0 1);  // orientation is important for separating regions
        include all;          // Take all faces (default)
        // include closest;   // Take the closest contiguous region of
                      // faces to the plane point
    }

    {
        action  new;
        type    faceZoneSet;
        name    electrode_s_p;
        source planeToFaceZone;
        point   (0 0 $posSepEnd);
        normal  (0 0 -1);  // orientation is important for separating regions
        include all;          // Take all faces (default)
        // include closest;   // Take the closest contiguous region of
                      // faces to the plane point
    }
);

